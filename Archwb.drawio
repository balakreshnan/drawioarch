<mxfile host="app.diagrams.net" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/147.0.0.0 Safari/537.36 Edg/147.0.0.0" pages="5">
  <diagram name="Questions" id="ap0p5e1snfkXhYOteo62">
    <mxGraphModel dx="1086" dy="767" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="MjL1HR9PDZ4IUghRATfm-1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;" value="&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;b&gt;Business Intent&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;ul&gt;&lt;li data-section-id=&quot;cthk9r&quot; data-start=&quot;682&quot; data-end=&quot;790&quot;&gt;What specific tasks should the agent perform—Q&amp;amp;A, decision support, automation, or multi-step workflows?&lt;br&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Is the agent assisting humans or acting autonomously?&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;What level of accuracy or trust is required for decisions?&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="200" width="180" x="120" y="130" as="geometry" />
        </mxCell>
        <mxCell id="MjL1HR9PDZ4IUghRATfm-2" parent="1" style="whiteSpace=wrap;html=1;aspect=fixed;align=left;" value="&lt;b&gt;Agent Behavior &amp;amp; Reasoning&lt;/b&gt;&lt;div&gt;&lt;ul&gt;&lt;li data-section-id=&quot;1s06hjv&quot; data-start=&quot;1063&quot; data-end=&quot;1138&quot;&gt;Should the agent perform multi-step reasoning or single-turn responses?&lt;/li&gt;&lt;li data-section-id=&quot;1krxzta&quot; data-start=&quot;1139&quot; data-end=&quot;1206&quot;&gt;Do we need tool usage (e.g., querying databases, calling APIs)?&lt;/li&gt;&lt;li data-section-id=&quot;1y70ycx&quot; data-start=&quot;1207&quot; data-end=&quot;1264&quot;&gt;Should the agent maintain memory across interactions?&lt;/li&gt;&lt;/ul&gt;&lt;br&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="180" width="180" x="360" y="130" as="geometry" />
        </mxCell>
        <mxCell id="MjL1HR9PDZ4IUghRATfm-3" parent="1" style="whiteSpace=wrap;html=1;aspect=fixed;" value="&lt;b&gt;Data Grounding - RAG/Agentic RAG&lt;/b&gt;&lt;div&gt;&lt;ul&gt;&lt;li data-section-id=&quot;1ikznp&quot; data-start=&quot;1364&quot; data-end=&quot;1444&quot;&gt;What data sources will ground the agent (documents, tables, streaming data)?&lt;/li&gt;&lt;li data-section-id=&quot;1ikznp&quot; data-start=&quot;1364&quot; data-end=&quot;1444&quot;&gt;How frequently does the data change?&lt;/li&gt;&lt;li data-section-id=&quot;y6fcwd&quot; data-start=&quot;1486&quot; data-end=&quot;1542&quot;&gt;Do we need real-time retrieval or periodic indexing?&lt;/li&gt;&lt;/ul&gt;&lt;br&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="185" width="185" x="615" y="135" as="geometry" />
        </mxCell>
        <mxCell id="MjL1HR9PDZ4IUghRATfm-4" parent="1" style="whiteSpace=wrap;html=1;aspect=fixed;" value="&lt;b&gt;Retrieval and Context Strategy&lt;/b&gt;&lt;div&gt;&lt;ul&gt;&lt;li data-section-id=&quot;19ut3uz&quot; data-start=&quot;1709&quot; data-end=&quot;1758&quot;&gt;What level of retrieval accuracy is required?&lt;/li&gt;&lt;li data-section-id=&quot;1escgrx&quot; data-start=&quot;1759&quot; data-end=&quot;1807&quot;&gt;Do we need hybrid search (keyword + vector)?&lt;/li&gt;&lt;li data-section-id=&quot;o13am7&quot; data-start=&quot;1808&quot; data-end=&quot;1851&quot;&gt;How large should the context window be?&lt;/li&gt;&lt;li data-section-id=&quot;o13am7&quot; data-start=&quot;1808&quot; data-end=&quot;1851&quot;&gt;Do we need graph or ontology?&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="180" width="180" x="120" y="360" as="geometry" />
        </mxCell>
        <mxCell id="MjL1HR9PDZ4IUghRATfm-5" parent="1" style="whiteSpace=wrap;html=1;aspect=fixed;align=left;" value="&lt;b&gt;Model Strategy&lt;/b&gt;&lt;div&gt;&lt;ul&gt;&lt;li data-section-id=&quot;ej6sr8&quot; data-start=&quot;1957&quot; data-end=&quot;2031&quot;&gt;Which models are we expected to use—open-source, proprietary, or both?&lt;/li&gt;&lt;li data-section-id=&quot;k9783z&quot; data-start=&quot;2032&quot; data-end=&quot;2096&quot;&gt;Do we need fine-tuning, or is prompt engineering sufficient?&lt;/li&gt;&lt;li data-section-id=&quot;vz68ma&quot; data-start=&quot;2097&quot; data-end=&quot;2163&quot;&gt;What are the latency and cost constraints for model inference?&lt;/li&gt;&lt;/ul&gt;&lt;br/&gt;&lt;br/&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="180" width="180" x="360" y="360" as="geometry" />
        </mxCell>
        <mxCell id="MjL1HR9PDZ4IUghRATfm-6" parent="1" style="whiteSpace=wrap;html=1;aspect=fixed;align=left;" value="&lt;b&gt;Tools &amp;amp; integration &amp;amp; A2A&lt;/b&gt;&lt;div&gt;&lt;ul&gt;&lt;li data-section-id=&quot;1bcpe2a&quot; data-start=&quot;2269&quot; data-end=&quot;2355&quot;&gt;What external systems should the agent interact with (APIs, databases, workflows)?&lt;/li&gt;&lt;li&gt;&lt;br&gt;&lt;/li&gt;&lt;li data-section-id=&quot;551yrc&quot; data-start=&quot;2356&quot; data-end=&quot;2440&quot;&gt;Do we need transactional actions (e.g., updating systems, triggering workflows)?&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="180" width="180" x="620" y="360" as="geometry" />
        </mxCell>
        <mxCell id="MjL1HR9PDZ4IUghRATfm-7" parent="1" style="whiteSpace=wrap;html=1;aspect=fixed;align=left;" value="&lt;b&gt;Orchestration &amp;amp; Workflow&lt;/b&gt;&lt;div&gt;&lt;ul&gt;&lt;li data-section-id=&quot;168fzd7&quot; data-start=&quot;2534&quot; data-end=&quot;2587&quot;&gt;Do we need single-agent or multi-agent workflows?&lt;br&gt;&lt;/li&gt;&lt;li data-section-id=&quot;ej7n6y&quot; data-start=&quot;2588&quot; data-end=&quot;2649&quot;&gt;Should tasks be deterministic, or allow dynamic planning?&lt;br&gt;&lt;/li&gt;&lt;li data-section-id=&quot;1bl7m37&quot; data-start=&quot;2650&quot; data-end=&quot;2698&quot;&gt;Do we need human-in-the-loop approval steps?&lt;/li&gt;&lt;/ul&gt;&lt;br&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="180" width="180" x="120" y="570" as="geometry" />
        </mxCell>
        <mxCell id="MjL1HR9PDZ4IUghRATfm-8" parent="1" style="whiteSpace=wrap;html=1;aspect=fixed;align=left;" value="&lt;b&gt;Evaluation &amp;amp; Quality&lt;/b&gt;&lt;div&gt;&lt;ul&gt;&lt;li data-section-id=&quot;1159mr0&quot; data-start=&quot;2804&quot; data-end=&quot;2893&quot;&gt;How will we evaluate the agent’s performance—accuracy, relevance, hallucination rate?&lt;br&gt;&lt;/li&gt;&lt;li data-section-id=&quot;1gxfhwm&quot; data-start=&quot;2894&quot; data-end=&quot;2948&quot;&gt;Do we have test datasets or evaluation frameworks?&lt;/li&gt;&lt;/ul&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="180" width="180" x="360" y="570" as="geometry" />
        </mxCell>
        <mxCell id="MjL1HR9PDZ4IUghRATfm-9" parent="1" style="whiteSpace=wrap;html=1;aspect=fixed;align=left;" value="&lt;b&gt;Safety &amp;amp; Guardrails&lt;/b&gt;&lt;div&gt;&lt;ul&gt;&lt;li data-section-id=&quot;eqqr09&quot; data-start=&quot;3080&quot; data-end=&quot;3157&quot;&gt;What guardrails are required (toxicity, hallucination, prompt injection)?&lt;/li&gt;&lt;li data-section-id=&quot;1ml5z9d&quot; data-start=&quot;3158&quot; data-end=&quot;3210&quot;&gt;Do we need to restrict access to sensitive data?&lt;/li&gt;&lt;li data-section-id=&quot;1xzcfbp&quot; data-start=&quot;3211&quot; data-end=&quot;3259&quot;&gt;Should outputs be auditable and explainable?&lt;/li&gt;&lt;/ul&gt;&lt;br/&gt;&lt;br/&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="180" width="180" x="620" y="570" as="geometry" />
        </mxCell>
        <mxCell id="MjL1HR9PDZ4IUghRATfm-10" parent="1" style="whiteSpace=wrap;html=1;aspect=fixed;align=left;" value="&lt;b&gt;Monitoring &amp;amp; Observability&lt;/b&gt;&lt;div&gt;&lt;ul&gt;&lt;li data-section-id=&quot;1c6japv&quot; data-start=&quot;3334&quot; data-end=&quot;3390&quot;&gt;How will we monitor agent performance in production?&lt;/li&gt;&lt;li data-section-id=&quot;18evmwh&quot; data-start=&quot;3391&quot; data-end=&quot;3442&quot;&gt;Do we track prompts, responses, and tool usage?&lt;/li&gt;&lt;li data-section-id=&quot;1ho4j7o&quot; data-start=&quot;3443&quot; data-end=&quot;3485&quot;&gt;How do we detect drift or degradation?&lt;/li&gt;&lt;/ul&gt;&lt;br/&gt;&lt;br/&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="180" width="180" x="120" y="800" as="geometry" />
        </mxCell>
        <mxCell id="MjL1HR9PDZ4IUghRATfm-11" parent="1" style="whiteSpace=wrap;html=1;aspect=fixed;align=left;" value="&lt;b&gt;Cost &amp;amp; Performance&lt;/b&gt;&lt;div&gt;&lt;ul&gt;&lt;li data-section-id=&quot;lp3e0t&quot; data-start=&quot;3521&quot; data-end=&quot;3569&quot;&gt;What are the cost constraints for LLM usage?&lt;/li&gt;&lt;li data-section-id=&quot;uwe8xy&quot; data-start=&quot;3570&quot; data-end=&quot;3611&quot;&gt;Do we need caching or response reuse?&lt;/li&gt;&lt;li data-section-id=&quot;1j3xfll&quot; data-start=&quot;3612&quot; data-end=&quot;3659&quot;&gt;What latency is acceptable per interaction?&lt;/li&gt;&lt;/ul&gt;&lt;br/&gt;&lt;br/&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="180" width="180" x="360" y="800" as="geometry" />
        </mxCell>
        <mxCell id="MjL1HR9PDZ4IUghRATfm-12" parent="1" style="whiteSpace=wrap;html=1;aspect=fixed;align=left;" value="&lt;b&gt;User Experience&lt;/b&gt;&lt;div&gt;&lt;ul&gt;&lt;li data-section-id=&quot;udphd&quot; data-start=&quot;3692&quot; data-end=&quot;3765&quot;&gt;What interface will users interact with (chat UI, API, embedded app)?&lt;/li&gt;&lt;li data-section-id=&quot;19tygw0&quot; data-start=&quot;3766&quot; data-end=&quot;3824&quot;&gt;Do we need multi-turn conversations or session memory?&lt;/li&gt;&lt;/ul&gt;&lt;br/&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="180" width="180" x="620" y="800" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
